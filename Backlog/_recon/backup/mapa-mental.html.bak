<!doctype html>
<html lang="pt-BR">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Mapa Mental · Backlog Squad IAF</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">
<style>
:root{
  --finza-blue:#1A1AFF;--finza-deep:#0F0F8C;--finza-soft:#E8E8FF;--finza-dark:#0A0A2E;
  --bg:#F4F4F7;--surface:#FFFFFF;--surface-2:#FAFAFC;
  --border:#E4E4ED;--border-strong:#D5D5E0;
  --text:#0A0A2E;--text-muted:#5C5C7A;--text-subtle:#8A8AA0;
  --urgent:#DC2626;--warning:#F59E0B;--success:#10B981;--info:#0EA5E9;
  --font-sans:'Inter',system-ui,sans-serif;--font-mono:'JetBrains Mono',monospace;
}
*,*::before,*::after{box-sizing:border-box}
html,body{margin:0;padding:0;height:100%;width:100%;overflow:hidden;background:var(--bg);color:var(--text);font-family:var(--font-sans);font-size:13px;letter-spacing:-0.005em;-webkit-font-smoothing:antialiased}

/* ===== Topbar ===== */
.topbar{position:fixed;left:0;top:0;right:0;height:54px;background:var(--surface);border-bottom:1px solid var(--border);padding:0 22px;display:flex;align-items:center;gap:18px;z-index:30}
.topbar .crumb{font-size:11.5px;color:var(--text-subtle);font-weight:500}
.topbar .crumb a{color:var(--finza-blue);font-weight:600;text-decoration:none}
.topbar .crumb a:hover{text-decoration:underline}
.topbar .crumb .cur{color:var(--text);font-weight:600}
.topbar .title{font-size:13.5px;font-weight:600;color:var(--text);letter-spacing:-0.005em}
.topbar .spacer{flex:1}
.topbar .search{position:relative}
.topbar .search input{padding:6px 12px 6px 30px;font-size:12px;border:1px solid var(--border);background:var(--surface-2);border-radius:99px;width:280px;outline:none;color:var(--text);font-family:var(--font-sans)}
.topbar .search input:focus{border-color:var(--finza-blue);background:var(--surface)}
.topbar .search::before{content:"";position:absolute;left:10px;top:50%;transform:translateY(-50%);width:14px;height:14px;background:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='%235C5C7A' stroke-width='2.5' stroke-linecap='round'><circle cx='11' cy='11' r='7'/><path d='m21 21-4.3-4.3'/></svg>") no-repeat center}
.topbar .meta{font-size:11px;color:var(--text-muted);font-weight:500;letter-spacing:.02em}
.topbar .meta strong{color:var(--text);font-weight:600}

/* ===== Layout ===== */
.layout{position:fixed;left:0;top:54px;right:0;bottom:0;display:grid;grid-template-columns:1fr 360px}

/* ===== Viewport (canvas) ===== */
#viewport{position:relative;overflow:hidden;background:#FAFAFC;background-image:radial-gradient(circle,#D5D5E0 1px,transparent 1px);background-size:30px 30px;background-position:0 0;cursor:grab;user-select:none;-webkit-user-select:none}
#viewport.panning{cursor:grabbing}
#viewport.panning .node{pointer-events:none}
#world{position:absolute;left:50%;top:50%;width:0;height:0;transform-origin:0 0}
#links{position:absolute;left:-3000px;top:-3000px;width:6000px;height:6000px;pointer-events:none;overflow:visible}
#links line, #links path{vector-effect:non-scaling-stroke}

.node{position:absolute;transform:translate(-50%,-50%);cursor:pointer;transition:box-shadow .15s,transform .15s}
.node.dragging{transition:none;z-index:50}
.node:hover{z-index:20}

/* Hub */
.hub-node{width:240px;background:linear-gradient(135deg,#0A0A2E 0%,#15154A 100%);border:2px solid var(--finza-blue);border-radius:16px;padding:18px 22px;color:#fff;text-align:center;box-shadow:0 20px 40px -10px rgba(10,10,46,.35);z-index:10}
.hub-node .hn{font-size:18px;font-weight:700;letter-spacing:-0.015em;line-height:1}
.hub-node .hsub{font-size:9.5px;letter-spacing:.16em;color:#A5B4FC;font-weight:700;margin-top:6px;text-transform:uppercase}
.hub-node .hd{font-size:10.5px;color:rgba(255,255,255,.62);margin-top:8px;padding-top:8px;border-top:1px solid rgba(255,255,255,.12);font-weight:500;letter-spacing:.02em}

/* Frente node */
.frente-node{width:230px;background:var(--surface);border:1px solid var(--border);border-radius:10px;overflow:hidden;box-shadow:0 2px 6px rgba(10,10,46,.06),0 16px 28px -16px rgba(10,10,46,.18)}
.frente-node .fc-band{height:8px;background:var(--c,var(--finza-blue))}
.frente-node .fc-body{padding:10px 14px 12px;display:flex;align-items:center;gap:10px}
.frente-node .fc-icon{width:28px;height:28px;border-radius:6px;background:var(--c);flex-shrink:0;display:flex;align-items:center;justify-content:center;color:#fff;font-size:13px;font-weight:700}
.frente-node .fc-text{flex:1;min-width:0}
.frente-node .fc-name{font-size:12.5px;font-weight:700;color:var(--text);letter-spacing:-0.005em;line-height:1.2;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.frente-node .fc-meta{font-size:10px;color:var(--text-muted);font-weight:600;letter-spacing:.04em;margin-top:2px;text-transform:uppercase}
.frente-node .fc-chev{flex-shrink:0;width:22px;height:22px;border-radius:50%;background:var(--bg);color:var(--text-muted);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;line-height:1}
.frente-node:hover{box-shadow:0 4px 10px rgba(10,10,46,.08),0 20px 30px -10px rgba(10,10,46,.25);transform:translate(-50%,-50%) translateY(-2px)}
.frente-node.on{border-color:var(--c)}
.frente-node.on .fc-chev{background:var(--c);color:#fff}
.frente-node.sel{outline:3px solid var(--c);outline-offset:2px}

/* Item node */
.item-node{width:210px;background:var(--surface);border:1px solid var(--border);border-radius:7px;overflow:hidden;display:flex;box-shadow:0 1px 3px rgba(10,10,46,.05),0 8px 16px -8px rgba(10,10,46,.12)}
.item-node .it-bar{width:4px;background:var(--cs,#9CA3AF);flex-shrink:0}
.item-node .it-body{flex:1;padding:7px 10px;min-width:0}
.item-node .it-id{font-family:var(--font-mono);font-size:9.5px;font-weight:700;color:var(--c,var(--finza-blue));letter-spacing:.04em}
.item-node .it-title{font-size:11px;font-weight:600;color:var(--text);line-height:1.3;margin-top:1px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.item-node .it-foot{display:flex;justify-content:space-between;align-items:center;margin-top:4px;gap:4px}
.item-node .it-st{font-size:8.5px;font-weight:700;letter-spacing:.06em;color:var(--text-muted);text-transform:uppercase}
.item-node .it-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.item-node .it-dot.urg{background:var(--urgent)}
.item-node .it-dot.alta{background:#F97316}
.item-node:hover{box-shadow:0 3px 8px rgba(10,10,46,.08),0 12px 20px -8px rgba(10,10,46,.22);transform:translate(-50%,-50%) translateY(-2px)}
.item-node.sel{outline:2.5px solid var(--c);outline-offset:2px;z-index:15}
.item-node.on{background:linear-gradient(180deg,var(--surface) 0%,#F9F9FE 100%)}
.item-node[data-status="cancelado"]{opacity:.55}
.item-node[data-status="cancelado"] .it-title{text-decoration:line-through}
.item-node[data-status="entregue"] .it-id::after{content:" ✓";color:var(--success)}

/* Bucket node (priority group) */
.bucket-node{width:200px;background:var(--surface);border:1px solid var(--border);border-radius:99px;display:flex;align-items:center;gap:8px;padding:5px 9px 5px 5px;box-shadow:0 2px 4px rgba(10,10,46,.06),0 10px 18px -8px rgba(10,10,46,.15)}
.bucket-node .bk-band{width:6px;height:30px;background:var(--c);border-radius:3px;flex-shrink:0}
.bucket-node .bk-body{flex:1;min-width:0;display:flex;flex-direction:column;gap:1px}
.bucket-node .bk-prio{font-size:10.5px;font-weight:700;color:var(--c);letter-spacing:.08em;text-transform:uppercase;display:flex;align-items:center;gap:6px;line-height:1.1}
.bucket-node .bk-prio .bk-count{font-family:var(--font-mono);font-size:9.5px;background:var(--bg);color:var(--text-muted);padding:1px 6px;border-radius:99px;font-weight:700;border:1px solid var(--border);text-transform:none;letter-spacing:.02em}
.bucket-node .bk-hint{font-size:9.5px;font-family:var(--font-mono);color:var(--text-subtle);font-weight:600;letter-spacing:.02em;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.bucket-node .bk-chev{width:22px;height:22px;border-radius:50%;background:var(--bg);color:var(--text-muted);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;flex-shrink:0;line-height:1}
.bucket-node.on{border-color:var(--c)}
.bucket-node.on .bk-chev{background:var(--c);color:#fff}
.bucket-node:hover{box-shadow:0 4px 8px rgba(10,10,46,.08),0 14px 22px -8px rgba(10,10,46,.22);transform:translate(-50%,-50%) translateY(-2px)}

/* Subtarefa node */
.sub-node{background:var(--surface-2);border:1px solid var(--border);border-radius:5px;padding:5px 9px;display:flex;align-items:center;gap:6px;font-size:10.5px;line-height:1.3;width:180px;box-shadow:0 1px 2px rgba(10,10,46,.04)}
.sub-node .sub-id{font-family:var(--font-mono);font-size:9px;font-weight:700;color:var(--text-subtle);letter-spacing:.04em;flex-shrink:0}
.sub-node .sub-t{flex:1;color:var(--text);font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.sub-node .sub-gate{flex-shrink:0;width:14px;height:14px;border-radius:50%;background:#FEF3C7;color:#92400E;border:1px solid #FDE68A;font-size:9px;font-weight:700;display:flex;align-items:center;justify-content:center}
.sub-node.gate{border-color:#FDE68A;background:#FFFBEB}
.sub-node:hover{border-color:var(--border-strong);background:var(--surface)}

/* dimmed when filtered */
.node.dim{opacity:0.18;pointer-events:none;filter:saturate(0.3)}
.node.match{outline:2px solid #10B981;outline-offset:3px}

/* ===== Side panel ===== */
#panel{background:var(--surface);border-left:1px solid var(--border);overflow-y:auto;padding:18px 20px 24px;display:flex;flex-direction:column;gap:16px}
#panel .ph{font-size:9.5px;letter-spacing:.18em;text-transform:uppercase;font-weight:700;color:var(--text-subtle);margin-bottom:8px}
#panel .pn-empty{font-size:12.5px;color:var(--text-muted);line-height:1.65}
#panel .pn-empty strong{display:block;font-size:14px;color:var(--text);font-weight:600;margin-bottom:8px;letter-spacing:-0.005em}
#panel .pn-empty ul{margin:8px 0 0;padding-left:18px;font-size:12px}
#panel .pn-empty li{margin:5px 0;line-height:1.55}
#panel .pn-empty kbd{font-family:var(--font-mono);font-size:10px;background:var(--bg);border:1px solid var(--border);padding:1px 5px;border-radius:3px;font-weight:600;color:var(--text)}

.detail-card{background:var(--surface-2);border:1px solid var(--border);border-left:3px solid var(--c,var(--finza-blue));border-radius:8px;padding:14px 16px}
.detail-card .d-id{font-family:var(--font-mono);font-size:11px;font-weight:700;color:var(--text-subtle);letter-spacing:.04em}
.detail-card .d-title{font-size:14px;font-weight:600;color:var(--text);line-height:1.4;margin:5px 0 10px;letter-spacing:-0.005em}
.detail-card .d-tags{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:12px}
.detail-card .d-grid{display:grid;grid-template-columns:auto 1fr;gap:6px 12px;font-size:11.5px;margin-bottom:10px}
.detail-card .d-grid dt{font-size:9.5px;letter-spacing:.12em;color:var(--text-muted);font-weight:700;text-transform:uppercase;padding-top:1px}
.detail-card .d-grid dd{margin:0;color:var(--text);font-weight:500}
.detail-card .d-grid dd.mono{font-family:var(--font-mono);font-size:10.5px}
.detail-card .d-grid dd.muted{color:var(--text-subtle);font-style:italic;font-weight:400}
.detail-card .d-context{font-size:12px;color:var(--text-muted);line-height:1.55;padding-top:10px;border-top:1px solid var(--border)}

.rels-section{margin-top:4px}
.rels-section h4{margin:0 0 8px;font-size:9.5px;font-weight:700;letter-spacing:.16em;color:var(--text-muted);text-transform:uppercase}
.rels-section .rel-chips{display:flex;flex-wrap:wrap;gap:5px}
.rel-chip{display:inline-flex;align-items:center;gap:5px;padding:4px 9px;background:var(--surface);border:1px solid var(--border);border-radius:99px;font-family:var(--font-mono);font-size:10.5px;font-weight:700;color:var(--text);cursor:pointer;transition:all .12s}
.rel-chip:hover{background:var(--finza-blue);color:#fff;border-color:var(--finza-blue)}
.rel-chip.dep{border-color:#FED7AA;background:#FFF7EE;color:#9A3412}
.rel-chip.dep:hover{background:#F59E0B;color:#fff;border-color:#F59E0B}
.rel-chip.blq{border-color:#FECACA;background:#FEF2F2;color:#991B1B}
.rel-chip.blq:hover{background:#EF4444;color:#fff;border-color:#EF4444}

.sub-list{display:flex;flex-direction:column;gap:5px}
.sub-list .sl-it{display:grid;grid-template-columns:auto 1fr auto;gap:8px;padding:6px 10px;background:var(--surface);border:1px solid var(--border);border-radius:5px;font-size:11px;line-height:1.4;align-items:center}
.sub-list .sl-it .sl-id{font-family:var(--font-mono);font-size:9.5px;font-weight:700;color:var(--text-subtle)}
.sub-list .sl-it .sl-t{color:var(--text);font-weight:500;line-height:1.35}
.sub-list .sl-it .sl-meta{font-family:var(--font-mono);font-size:9.5px;color:var(--text-subtle);white-space:nowrap}
.sub-list .sl-it.gate{background:#FFFBEB;border-color:#FDE68A}
.sub-list .sl-it.gate .sl-id{color:#92400E}

/* Sub-node selection */
.sub-node.sel{outline:2.5px solid var(--finza-blue);outline-offset:2px;background:#EEF2FF;z-index:15}

/* Rich panel cards */
.panel-section{margin-top:4px}
.panel-section h4{margin:0 0 8px;font-size:9.5px;font-weight:700;letter-spacing:.16em;color:var(--text-muted);text-transform:uppercase;display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.panel-section h4 .h4-count{font-family:var(--font-mono);font-size:9px;background:var(--bg);border:1px solid var(--border);color:var(--text);padding:1px 6px;border-radius:99px;font-weight:700;letter-spacing:.02em;text-transform:none}
.panel-text{font-size:12px;color:var(--text);line-height:1.6;background:var(--surface-2);border:1px solid var(--border);border-radius:6px;padding:11px 13px;white-space:pre-wrap}
.panel-text.muted{color:var(--text-muted);font-size:11.5px}
.panel-text.history{border-left:3px solid var(--finza-blue);padding-left:13px}
.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-top:4px}
.kpi-cell{background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:8px 10px;text-align:left}
.kpi-cell .kpi-l{font-size:8.5px;letter-spacing:.14em;color:var(--text-muted);font-weight:700;text-transform:uppercase}
.kpi-cell .kpi-v{font-size:14px;font-weight:700;color:var(--text);font-family:var(--font-mono);margin-top:3px;letter-spacing:-0.01em}
.kpi-cell.score{background:var(--finza-blue);border-color:var(--finza-blue)}
.kpi-cell.score .kpi-l{color:rgba(255,255,255,.78)}
.kpi-cell.score .kpi-v{color:#fff;font-size:15px}
.ca-list{display:flex;flex-direction:column;gap:8px}
.ca-card{background:var(--surface);border:1px solid var(--border);border-left:3px solid #10B981;border-radius:6px;padding:10px 12px;font-size:11.5px;line-height:1.5}
.ca-card .ca-line{display:grid;grid-template-columns:38px 1fr;gap:8px;margin-bottom:4px}
.ca-card .ca-line:last-child{margin-bottom:0}
.ca-card .ca-tag{font-size:8.5px;letter-spacing:.1em;font-weight:700;text-transform:uppercase;color:#047857;background:#ECFDF5;border:1px solid #A7F3D0;padding:1px 4px;border-radius:3px;align-self:start;text-align:center;line-height:1.4}
.ca-card .ca-line.w .ca-tag{color:#92400E;background:#FFFBEB;border-color:#FDE68A}
.ca-card .ca-line.t .ca-tag{color:#1A1AFF;background:#EEF2FF;border-color:#C7CEFF}
.bullet-list{display:flex;flex-direction:column;gap:5px;margin:0;padding:0;list-style:none}
.bullet-list li{background:var(--surface);border:1px solid var(--border);border-radius:5px;padding:7px 11px 7px 24px;font-size:11.5px;color:var(--text);line-height:1.5;position:relative}
.bullet-list li::before{content:"";position:absolute;left:10px;top:13px;width:5px;height:5px;border-radius:50%;background:var(--text-subtle)}
.bullet-list.risk li::before{background:#EF4444}
.bullet-list.prem li::before{background:#0EA5E9}
.tags-row{display:flex;flex-wrap:wrap;gap:4px}
.tag-chip{font-family:var(--font-mono);font-size:9.5px;font-weight:700;padding:2px 7px;background:var(--bg);border:1px solid var(--border);border-radius:99px;color:var(--text-muted);letter-spacing:.02em}
.subs-list{display:flex;flex-direction:column;gap:5px}
.sub-card{display:grid;grid-template-columns:auto 1fr auto;gap:8px;padding:7px 11px;background:var(--surface);border:1px solid var(--border);border-radius:5px;font-size:11px;line-height:1.4;align-items:center;cursor:pointer;transition:border-color .12s,background .12s}
.sub-card:hover{border-color:var(--finza-blue);background:#F8F8FF}
.sub-card.sel{border-color:var(--finza-blue);background:#EEF2FF;outline:1px solid var(--finza-blue);outline-offset:-1px}
.sub-card.gate{background:#FFFBEB;border-color:#FDE68A}
.sub-card.gate:hover{background:#FEF3C7}
.sub-card .sc-id{font-family:var(--font-mono);font-size:9.5px;font-weight:700;color:var(--text-subtle);min-width:36px}
.sub-card.gate .sc-id{color:#92400E}
.sub-card .sc-t{color:var(--text);font-weight:500;line-height:1.35;min-width:0;overflow:hidden}
.sub-card .sc-meta{font-family:var(--font-mono);font-size:9px;color:var(--text-subtle);white-space:nowrap;text-align:right}
.back-btn{display:inline-flex;align-items:center;gap:4px;font-size:11px;color:var(--finza-blue);font-weight:600;cursor:pointer;background:transparent;border:0;padding:3px 6px 3px 0;letter-spacing:.01em}
.back-btn:hover{text-decoration:underline}
.contextual-section{margin-top:14px;padding-top:14px;border-top:1px solid var(--border)}
.bucket-pill-row{display:flex;flex-wrap:wrap;gap:4px}
.bucket-pill{display:inline-flex;align-items:center;gap:4px;padding:3px 9px;border-radius:99px;font-size:10px;font-weight:700;letter-spacing:.04em;cursor:pointer;border:1px solid;text-transform:uppercase;transition:transform .1s}
.bucket-pill:hover{transform:translateY(-1px)}
.bucket-pill .bp-n{font-family:var(--font-mono);font-size:9px;background:rgba(255,255,255,.5);padding:1px 5px;border-radius:99px}

.badge{display:inline-flex;padding:2px 7px;font-size:9.5px;font-weight:700;letter-spacing:.06em;border-radius:3px;border:1px solid transparent;text-transform:uppercase}
.badge.urgente{background:#FFF0F0;color:#B91C1C;border-color:#FECACA}
.badge.alta{background:#FFF4EC;color:#9A3412;border-color:#FED7AA}
.badge.media{background:#FFFBEB;color:#92400E;border-color:#FDE68A}
.badge.baixa{background:#F4F4F7;color:#52525B;border-color:#E4E4ED}
.badge.a-refinar{background:#F4F4F7;color:#52525B;border-color:#E4E4ED}
.badge.em-refinamento{background:#FFFBEB;color:#92400E;border-color:#FDE68A}
.badge.refinado{background:#ECFEFF;color:#0E7490;border-color:#A5F3FC}
.badge.em-curso{background:#EEF2FF;color:#1A1AFF;border-color:#C7CEFF}
.badge.bloqueado{background:#FEF2F2;color:#991B1B;border-color:#FECACA}
.badge.validacao{background:#FAF5FF;color:#6B21A8;border-color:#E9D5FF}
.badge.entregue{background:#ECFDF5;color:#047857;border-color:#A7F3D0}
.badge.cancelado{background:#F4F4F7;color:#52525B;border-color:#E4E4ED}

/* Toolbar */
.toolbar{position:absolute;left:14px;bottom:14px;display:flex;gap:6px;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:5px;box-shadow:0 4px 12px rgba(10,10,46,.08);z-index:20}
.toolbar button{background:var(--surface);border:0;padding:6px 10px;font-size:11.5px;font-weight:600;color:var(--text-muted);cursor:pointer;border-radius:5px;letter-spacing:.02em;display:inline-flex;align-items:center;gap:4px}
.toolbar button:hover{background:var(--bg);color:var(--text)}
.toolbar button.primary{color:var(--finza-blue)}
.toolbar .zoom-val{padding:6px 10px;font-family:var(--font-mono);font-size:11px;color:var(--text-muted);min-width:48px;text-align:center;border-left:1px solid var(--border);border-right:1px solid var(--border)}

.hint{position:absolute;right:14px;bottom:14px;background:rgba(255,255,255,0.92);border:1px solid var(--border);padding:8px 12px;border-radius:8px;font-size:10.5px;color:var(--text-muted);line-height:1.6;backdrop-filter:blur(6px);max-width:280px;z-index:20;box-shadow:0 4px 12px rgba(10,10,46,.05)}
.hint kbd{font-family:var(--font-mono);font-size:9.5px;background:var(--bg);border:1px solid var(--border);padding:1px 5px;border-radius:3px;font-weight:600;color:var(--text)}
.hint strong{color:var(--text);font-weight:600}

@media (max-width:1100px){
  .layout{grid-template-columns:1fr}
  #panel{display:none}
}
</style>
</head>
