    { "id": "BST02", "frente": "estrategica", "title": "Implementar coleta de NPS no fim da jornada Finza via IA", "status": "a-refinar", "prioridade": "alta", "esforco": "M", "valor_negocio": "alto", "rice": { "reach": 7, "impact": 7, "confidence": 5, "effort": 5, "score": 4.9 }, "dependencias": [], "bloqueia": [], "deadline": "2026-Q3", "subtarefas": [ { "id": "ST-1", "title": "Definir formato da pesquisa (SEM ISSO, CÓDIGO É ESPECULATIVO)", "status": "a-refinar", "isGate": true }, { "id": "ST-2", "title": "Identificar gatilho fim da jornada (sessão com Marco)", "status": "a-refinar", "isGate": false }, { "id": "ST-3", "title": "Decidir agente que envia (Valentina recomendado vs dedicado)", "status": "a-refinar", "isGate": false }, { "id": "ST-4", "title": "Definir momento exato do envio (24h? 7d? logo após receber máquina?)", "status": "a-refinar", "isGate": false }, { "id": "ST-5", "title": "Definir taxa de resposta esperada (baseline)", "status": "a-refinar", "isGate": false }, { "id": "ST-6", "title": "Implementar envio + coleta + persistência", "status": "a-refinar", "isGate": false }, { "id": "ST-7", "title": "Dashboard NPS por carteira/originador/mês", "status": "a-refinar", "isGate": false }, { "id": "ST-8", "title": "Definir ação para score baixo (CHAVE DO PROJETO — sem isso NPS vira vaidade)", "status": "a-refinar", "isGate": true }, { "id": "ST-9", "title": "Calibragem com 100 respostas iniciais (sem viés grosseiro)", "status": "a-refinar", "isGate": false } ], "tags": ["nps", "jornada", "valentina", "diretoria", "satisfacao"] }
  ]
}
</script>
<script>
const DATA = JSON.parse(document.getElementById('map-data').textContent);
const FRENTES = Object.fromEntries(DATA.frentes.map(f => [f.key, f]));
const ITEMS = DATA.items;
const ITEMS_BY_ID = Object.fromEntries(ITEMS.map(i => [i.id, i]));

const STATUS_LABELS = {'a-refinar':'A refinar','em-refinamento':'Em refinamento','refinado':'Refinado','em-curso':'Em curso','bloqueado':'Bloqueado','validacao':'Em validação','entregue':'Entregue','cancelado':'Cancelado'};
const STATUS_COLORS = {'a-refinar':'#9CA3AF','em-refinamento':'#F59E0B','refinado':'#0EA5E9','em-curso':'#1A1AFF','bloqueado':'#EF4444','validacao':'#A855F7','entregue':'#10B981','cancelado':'#9CA3AF'};
const PRIO_LABELS = {urgente:'Urgente',alta:'Alta',media:'Média',baixa:'Baixa'};
const FRENTE_LETTER = {'bitrix-automacoes':'B','torre':'T','clara':'C','esperanza':'E','valentina':'V','livia':'L','estrategica':'S'};
const STORAGE = 'mindmap.iaf.v9';

try {
  const prior = localStorage.getItem('mindmap.iaf.v8') || localStorage.getItem('mindmap.iaf.v7') || localStorage.getItem('mindmap.iaf.v6');
  if(prior && !localStorage.getItem(STORAGE)){
    const o = JSON.parse(prior);
    if(o.positions){
      o.positions = Object.fromEntries(Object.entries(o.positions).filter(([k]) => !k.startsWith('sub:')));
    }
    localStorage.setItem(STORAGE, JSON.stringify(o));
  }
} catch(e){}

// ===== State =====
let pan = {x:0, y:0};
let zoom = 1;
let expandedFrentes = new Set();
let expandedBuckets = new Set(); // keys 'frenteKey|prio'
let expandedItems = new Set();
let selectedItem = null;
let selectedFrente = null;
let selectedSub = null; // {itemId, subId}
let positions = {};
let searchQ = '';
let matchedIds = new Set();
let showHistorico = false;

// Load persisted state
try{
  const saved = JSON.parse(localStorage.getItem(STORAGE) || '{}');
  if(saved.positions) positions = saved.positions;
  if(saved.pan) pan = saved.pan;
  if(saved.zoom) zoom = saved.zoom;
  if(saved.expandedFrentes) expandedFrentes = new Set(saved.expandedFrentes);
  if(saved.expandedBuckets) expandedBuckets = new Set(saved.expandedBuckets);
  if(typeof saved.showHistorico === 'boolean') showHistorico = saved.showHistorico;
}catch(e){}

function persist(){
  try{
    localStorage.setItem(STORAGE, JSON.stringify({
      positions, pan, zoom,
      expandedFrentes:[...expandedFrentes],
      expandedBuckets:[...expandedBuckets],
      showHistorico
    }));
  }catch(e){}
}

// ===== Helpers =====
const NS = 'http://www.w3.org/2000/svg';
function svgEl(tag, attrs){
  const e = document.createElementNS(NS, tag);
  for(const k in attrs) e.setAttribute(k, attrs[k]);
  return e;
}
function escapeHtml(s){return (s==null?'':String(s)).replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]))}

function ensureFrentePositions(){
  DATA.frentes.forEach((f, i) => {
    const key = 'frente:'+f.key;
    if(!positions[key]){
      const angle = (-90 + i * (360/DATA.frentes.length)) * Math.PI/180;
      positions[key] = {x: 460*Math.cos(angle), y: 460*Math.sin(angle)};
    }
  });
}

// ===== Priority / impact ordering =====
const PRIO_ORDER = ['urgente','alta','media','baixa'];
const PRIO_LBL = {urgente:'Urgentes', alta:'Altas', media:'Médias', baixa:'Baixas'};
const PRIO_COLOR = {urgente:'#DC2626', alta:'#F97316', media:'#F59E0B', baixa:'#9CA3AF'};
const STATUS_RANK = {'em-curso':0,'em-refinamento':1,'refinado':2,'validacao':3,'bloqueado':4,'a-refinar':5,'entregue':6,'cancelado':7};

function activeItems(fk){
  // Cancelados nunca aparecem no mapa (não contam no backlog)
  const its = ITEMS.filter(i => i.frente === fk && i.status !== 'cancelado');
  if(showHistorico) return its;
  return its.filter(i => i.status !== 'entregue');
}
function bucketsForFrente(fk){
  const its = activeItems(fk);
  return PRIO_ORDER.filter(p => its.some(i => i.prioridade === p));
}
function sortByImpact(a, b){
  const sa = STATUS_RANK[a.status]; const sb = STATUS_RANK[b.status];
  const saV = sa==null ? 9 : sa, sbV = sb==null ? 9 : sb;
  if(saV !== sbV) return saV - sbV;
  const ra = a.rice || 0, rb = b.rice || 0;
  if(ra !== rb) return rb - ra;
  const da = a.deadline && /^\d{4}-\d{2}-\d{2}$/.test(a.deadline) ? +new Date(a.deadline) : Infinity;
  const db = b.deadline && /^\d{4}-\d{2}-\d{2}$/.test(b.deadline) ? +new Date(b.deadline) : Infinity;
  return da - db;
}

function ensureBucketPositions(fk){
  const buckets = bucketsForFrente(fk);
  if(!buckets.length) return;
  const fpos = positions['frente:'+fk];
  const a0 = Math.atan2(fpos.y, fpos.x);
  const N = buckets.length;
  const spread = (N === 1 ? 0 : N === 2 ? 50 : N === 3 ? 90 : 130) * Math.PI/180;
  const r = 220;
  buckets.forEach((p, i) => {
    const t = N === 1 ? 0.5 : i/(N-1);
    const a = a0 - spread/2 + t*spread;
    const key = 'bucket:'+fk+':'+p;
    if(!positions[key]){
      positions[key] = {x: fpos.x + r*Math.cos(a), y: fpos.y + r*Math.sin(a)};
    }
  });
}
// ===== Layout helpers (slot-aware arc) =====
// Lays out N children around a parent. Uses a CONSTANT spread across rings,
// so slot widths are predictable. Half-slot stagger offsets odd rings so
// items in adjacent rings don't fall on the same radial line.
function layoutAround(parentPos, refPos, n, opts){
  const dx = parentPos.x - refPos.x, dy = parentPos.y - refPos.y;
  const a0 = Math.atan2(dy, dx);
  const baseR = opts.baseR;
  const ringStep = opts.ringStep; // MUST be >= node width to prevent radial overlap
  const minSep = opts.minSep;
  const spread = opts.spread * Math.PI/180;
  const positions = [];
  let placed = 0, ri = 0;
  while(placed < n){
    const r = baseR + ri*ringStep;
    const arcLen = spread * r;
    const slots = Math.max(1, Math.floor(arcLen / minSep));
    const take = Math.min(slots, n - placed);
    const slotWidth = spread / slots;
    const offset = (ri % 2) * (slotWidth / 2);
    for(let j = 0; j < take; j++){
      const t = (j + 0.5) / slots;
      const a = a0 - spread/2 + t*spread + offset;
      positions.push({x: parentPos.x + r*Math.cos(a), y: parentPos.y + r*Math.sin(a)});
    }
    placed += take;
    ri++;
    if(ri > 8) break;
  }
  return positions;
}
function ensureItemPositions(fk, prio){
  const items = activeItems(fk).filter(i => i.prioridade === prio).sort(sortByImpact);
  if(!items.length) return;
  const bpos = positions['bucket:'+fk+':'+prio];
  const fpos = positions['frente:'+fk];
  if(!bpos || !fpos) return;
  // item-node ~210px wide → ringStep 220 ensures no radial overlap
  const pts = layoutAround(bpos, fpos, items.length, {
    baseR: 200, ringStep: 220, minSep: 240, spread: 160
  });
  items.forEach((it, i) => {
    const key = 'item:'+it.id;
    if(!positions[key]) positions[key] = pts[i];
  });
}
function ensureSubPositions(itemId){
  const item = ITEMS_BY_ID[itemId];
  if(!item || !item.subtarefas.length) return;
  const ipos = positions['item:'+itemId];
  const fpos = positions['frente:'+item.frente];
  if(!ipos || !fpos) return;
  // sub-node ~190px wide → ringStep 195 ensures no radial overlap;
  // baseR 205 keeps the first ring just clear of the item-node bbox (item ~210 wide)
  const pts = layoutAround(ipos, fpos, item.subtarefas.length, {
    baseR: 205, ringStep: 195, minSep: 215, spread: 210
  });
  item.subtarefas.forEach((st, i) => {
    const key = 'sub:'+itemId+':'+st.id;
    if(!positions[key]) positions[key] = pts[i];
  });
}

// ===== DOM refs =====
const viewport = document.getElementById('viewport');
const world = document.getElementById('world');
const links = document.getElementById('links');
const panel = document.getElementById('panel');
const zoomVal = document.getElementById('zoom-val');
const searchInput = document.getElementById('search');

// ===== Transform =====
function applyTransform(){
  world.style.transform = `translate(${pan.x}px, ${pan.y}px) scale(${zoom})`;
  zoomVal.textContent = Math.round(zoom*100) + '%';
}

// ===== Render =====
function render(){
  // Clear node DOM
  Array.from(world.querySelectorAll('.node')).forEach(n => n.remove());
  // Hub
  const hub = document.createElement('div');
  hub.className = 'node hub-node';
  hub.style.left = '0px';
  hub.style.top = '0px';
  hub.innerHTML = `
    <div class="hn">Squad IAF</div>
    <div class="hsub">Inteligência Artificial Finza</div>
    <div class="hd">30 itens · 7 frentes</div>
  `;
  world.appendChild(hub);

  // Frentes
  DATA.frentes.forEach(f => {
    const pos = positions['frente:'+f.key];
    const count = ITEMS.filter(i => i.frente === f.key).length;
    const el = document.createElement('div');
    const isOn = expandedFrentes.has(f.key);
    el.className = 'node frente-node' + (isOn ? ' on' : '') + (selectedFrente === f.key ? ' sel' : '');
    el.style.left = pos.x + 'px';
    el.style.top = pos.y + 'px';
    el.style.setProperty('--c', f.color);
    el.dataset.key = 'frente:'+f.key;
    el.innerHTML = `
      <div class="fc-band"></div>
      <div class="fc-body">
        <div class="fc-icon">${FRENTE_LETTER[f.key]||'·'}</div>
        <div class="fc-text">
          <div class="fc-name">${escapeHtml(f.label.split('·')[0].trim())}</div>
          <div class="fc-meta">${activeItems(f.key).length + (showHistorico ? '' : ' ativos')} · ${escapeHtml(f.sponsor)}</div>
        </div>
        <div class="fc-chev">${isOn ? '−' : '+'}</div>
      </div>
    `;
    attachInteractions(el, () => toggleFrente(f.key));
    world.appendChild(el);
  });

  // Buckets (priority groups) and then items inside expanded buckets
  const visibleItemIds = new Set();
  expandedFrentes.forEach(fk => {
    ensureBucketPositions(fk);
    const buckets = bucketsForFrente(fk);
    buckets.forEach(prio => {
      const bpos = positions['bucket:'+fk+':'+prio];
      if(!bpos) return;
      const items = activeItems(fk).filter(i => i.prioridade === prio).sort(sortByImpact);
      const bkey = fk+'|'+prio;
      const isOn = expandedBuckets.has(bkey);
      // Bucket node
      const bel = document.createElement('div');
      bel.className = 'node bucket-node' + (isOn ? ' on' : '');
      bel.style.left = bpos.x + 'px';
      bel.style.top = bpos.y + 'px';
      bel.style.setProperty('--c', PRIO_COLOR[prio]);
      bel.style.setProperty('--cf', FRENTES[fk].color);
      bel.dataset.key = 'bucket:'+fk+':'+prio;
      const hint = items.slice(0,2).map(i=>i.id).join(' · ') + (items.length>2 ? ' · +'+(items.length-2) : '');
      bel.innerHTML = `
        <div class="bk-band"></div>
        <div class="bk-body">
          <div class="bk-prio">${PRIO_LBL[prio]}<span class="bk-count">${items.length}</span></div>
          <div class="bk-hint">${hint || '\u2014'}</div>
        </div>
        <div class="bk-chev">${isOn ? '−' : '+'}</div>
      `;
      attachInteractions(bel, () => toggleBucket(fk, prio));
      world.appendChild(bel);
      // Items inside expanded bucket
      if(isOn){
        ensureItemPositions(fk, prio);
        items.forEach(it => {
          visibleItemIds.add(it.id);
          const ipos = positions['item:'+it.id];
          if(!ipos) return;
          const f = FRENTES[it.frente];
          const iel = document.createElement('div');
          iel.className = 'node item-node' + (selectedItem === it.id ? ' sel' : '') + (expandedItems.has(it.id) ? ' on' : '');
          iel.style.left = ipos.x + 'px';
          iel.style.top = ipos.y + 'px';
          iel.style.setProperty('--c', f.color);
          iel.style.setProperty('--cs', STATUS_COLORS[it.status]);
          iel.dataset.key = 'item:'+it.id;
          iel.dataset.status = it.status;
          const dotCls = it.prioridade === 'urgente' ? 'urg' : it.prioridade === 'alta' ? 'alta' : '';
          iel.innerHTML = `
            <div class="it-bar"></div>
            <div class="it-body">
              <div class="it-id">${it.id}</div>
              <div class="it-title">${escapeHtml(it.title)}</div>
              <div class="it-foot">
                <span class="it-st">${STATUS_LABELS[it.status]}</span>
                ${dotCls ? '<span class="it-dot '+dotCls+'"></span>' : ''}
              </div>
            </div>
          `;
          attachInteractions(iel, () => selectItem(it.id));
          world.appendChild(iel);
        });
      }
    });
  });

  // Subtarefas
  expandedItems.forEach(iid => {
    if(!visibleItemIds.has(iid)) return;
    ensureSubPositions(iid);
    const item = ITEMS_BY_ID[iid];
    item.subtarefas.forEach(st => {
      const pos = positions['sub:'+iid+':'+st.id];
      const el = document.createElement('div');
      el.className = 'node sub-node' + (st.isGate ? ' gate' : '');
      el.style.left = pos.x + 'px';
      el.style.top = pos.y + 'px';
      el.dataset.key = 'sub:'+iid+':'+st.id;
      el.innerHTML = `
        ${st.isGate ? '<span class="sub-gate">!</span>' : ''}
        <span class="sub-id">${st.id}</span>
        <span class="sub-t">${escapeHtml(st.title)}</span>
      `;
      if(selectedSub && selectedSub.itemId === iid && selectedSub.subId === st.id) el.classList.add('sel');
      attachInteractions(el, () => selectSubtarefa(iid, st.id));
      world.appendChild(el);
    });
  });

  // SVG links
  renderLinks(visibleItemIds);

  // Search dim/highlight
  applySearchVisual();

  // Side panel
  renderPanel();

  applyTransform();
}

function renderLinks(visibleItemIds){
  // Clear
  while(links.firstChild) links.removeChild(links.firstChild);

  // Defs: arrow markers
  const defs = svgEl('defs', {});
  const mk = (id, color) => {
    const m = svgEl('marker', {id, markerWidth:8, markerHeight:8, refX:7, refY:4, orient:'auto-start-reverse', markerUnits:'userSpaceOnUse'});
    const p = svgEl('path', {d:'M0,0 L8,4 L0,8 z', fill:color});
    m.appendChild(p);
    return m;
  };
  defs.appendChild(mk('arr-dep', '#F59E0B'));
  defs.appendChild(mk('arr-blq', '#EF4444'));
  links.appendChild(defs);

  const O = 3000; // offset

  // Hub → frentes (always)
  DATA.frentes.forEach(f => {
    const fpos = positions['frente:'+f.key];
    // direction
    const dx = fpos.x, dy = fpos.y;
    const len = Math.sqrt(dx*dx+dy*dy);
    const ux = dx/len, uy = dy/len;
    // hub edge ≈ 100px from center; frente edge ≈ 130px from center (frente size 230x96)
    const x1 = O + ux*95;
    const y1 = O + uy*55;
    const x2 = O + fpos.x - ux*130;
    const y2 = O + fpos.y - uy*45;
    links.appendChild(svgEl('line', {x1, y1, x2, y2, stroke:f.color, 'stroke-width':2.5, 'stroke-opacity':expandedFrentes.has(f.key) ? 0.85 : 0.45}));
  });

  // Frente → buckets, and bucket → items (when expanded)
  expandedFrentes.forEach(fk => {
    const fpos = positions['frente:'+fk];
    bucketsForFrente(fk).forEach(prio => {
      const bpos = positions['bucket:'+fk+':'+prio];
      if(!bpos) return;
      links.appendChild(svgEl('line', {
        x1: O+fpos.x, y1: O+fpos.y,
        x2: O+bpos.x, y2: O+bpos.y,
        stroke: PRIO_COLOR[prio],
        'stroke-width': 1.8,
        'stroke-opacity': 0.55
      }));
      if(expandedBuckets.has(fk+'|'+prio)){
        activeItems(fk).filter(i => i.prioridade === prio).forEach(it => {
          const ipos = positions['item:'+it.id];
          if(!ipos) return;
          links.appendChild(svgEl('line', {
            x1: O+bpos.x, y1: O+bpos.y,
            x2: O+ipos.x, y2: O+ipos.y,
            stroke: FRENTES[fk].color,
            'stroke-width': 1,
            'stroke-opacity': 0.32
          }));
        });
      }
    });
  });

  // Item → subtarefas
  expandedItems.forEach(iid => {
    if(!visibleItemIds.has(iid)) return;
    const ipos = positions['item:'+iid];
    ITEMS_BY_ID[iid].subtarefas.forEach(st => {
      const spos = positions['sub:'+iid+':'+st.id];
      if(!spos) return;
      links.appendChild(svgEl('line', {
        x1: O+ipos.x, y1: O+ipos.y,
        x2: O+spos.x, y2: O+spos.y,
        stroke: '#9CA3AF',
        'stroke-width': 1,
        'stroke-opacity': 0.55,
        'stroke-dasharray': '3,3'
      }));
    });
  });

  // Item ↔ Item dependencies/blocks
  ITEMS.forEach(i => {
    if(!visibleItemIds.has(i.id)) return;
    const a = positions['item:'+i.id];
    // depends on
    i.dependencias.forEach(depId => {
      if(!visibleItemIds.has(depId)) return;
      const b = positions['item:'+depId];
      // curve from b → a (dep flows TO i)
      const mx = (a.x+b.x)/2, my = (a.y+b.y)/2;
      const dx = a.x - b.x, dy = a.y - b.y;
      const len = Math.sqrt(dx*dx+dy*dy) || 1;
      const px = -dy/len * 28, py = dx/len * 28;
      links.appendChild(svgEl('path', {
        d: `M ${O+b.x} ${O+b.y} Q ${O+mx+px} ${O+my+py} ${O+a.x} ${O+a.y}`,
        stroke: '#F59E0B',
        'stroke-width': 1.6,
        'stroke-dasharray': '5,3',
        fill: 'none',
        opacity: 0.85,
        'marker-end': 'url(#arr-dep)'
      }));
    });
    // blocks
    i.bloqueia.forEach(blockId => {
      if(!visibleItemIds.has(blockId)) return;
      const b = positions['item:'+blockId];
      const mx = (a.x+b.x)/2, my = (a.y+b.y)/2;
      const dx = b.x - a.x, dy = b.y - a.y;
      const len = Math.sqrt(dx*dx+dy*dy) || 1;
      const px = -dy/len * (-28), py = dx/len * (-28);
      links.appendChild(svgEl('path', {
        d: `M ${O+a.x} ${O+a.y} Q ${O+mx+px} ${O+my+py} ${O+b.x} ${O+b.y}`,
        stroke: '#EF4444',
        'stroke-width': 1.6,
        'stroke-dasharray': '7,4',
        fill: 'none',
        opacity: 0.85,
        'marker-end': 'url(#arr-blq)'
      }));
    });
  });
}

function renderPanel(){
  // === Subtarefa selecionada ===
  if(selectedSub){
    const it = ITEMS_BY_ID[selectedSub.itemId];
    const f = FRENTES[it.frente];
    const st = it.subtarefas.find(s => s.id === selectedSub.subId);
    if(!st){selectedSub = null; return renderPanel();}
    const depsHtml = (st.dependencias||[]).length
      ? `<div class="panel-section"><h4>Depende de <span class="h4-count">${st.dependencias.length}</span></h4><div class="tags-row">${st.dependencias.map(d=>`<span class="tag-chip">${escapeHtml(d)}</span>`).join('')}</div></div>` : '';
    panel.innerHTML = `
      <div>
        <button class="back-btn" id="back-to-item">← voltar para ${it.id}</button>
        <div class="ph" style="margin-top:8px">Subtarefa</div>
        <div class="detail-card" style="--c:${st.isGate?'#F59E0B':f.color}">
          <div class="d-id">${st.id} · ${escapeHtml(f.label.split('·')[0].trim())} / ${it.id}</div>
          <div class="d-title">${escapeHtml(st.title)}</div>
          <div class="d-tags">
            <span class="badge ${st.status}">${STATUS_LABELS[st.status]||st.status}</span>
            ${st.isGate?'<span class="badge alta" style="background:#FEF3C7;color:#92400E;border-color:#FDE68A">⚠ Gate</span>':''}
            ${st.esforco?`<span class="badge baixa">${st.esforco}</span>`:''}
          </div>
          <dl class="d-grid">
            <dt>Responsável</dt><dd>${escapeHtml(st.responsavel||'—')}</dd>
            <dt>Prazo</dt><dd class="${st.prazo?'mono':'muted'}">${st.prazo||'— a definir'}</dd>
            <dt>Esforço</dt><dd class="mono">${st.esforco||'—'}</dd>
          </dl>
        </div>
      </div>
      ${st.description ? `<div class="panel-section"><h4>Descrição</h4><div class="panel-text">${escapeHtml(st.description)}</div></div>` : ''}
      ${depsHtml}
      <div class="panel-section"><h4>Contexto do item-pai</h4>
        <div class="sub-card" data-goto-item="${it.id}">
          <span class="sc-id">${it.id}</span>
          <span class="sc-t">${escapeHtml(it.title)}</span>
          <span class="sc-meta">${STATUS_LABELS[it.status]}</span>
        </div>
      </div>
    `;
    document.getElementById('back-to-item').onclick = () => { selectedSub = null; render(); persist(); };
    panel.querySelectorAll('[data-goto-item]').forEach(c => c.onclick = () => navigateToItem(c.dataset.gotoItem));
    return;
  }

  // === Item selecionado ===
  if(selectedItem){
    const it = ITEMS_BY_ID[selectedItem];
    const f = FRENTES[it.frente];

    // Contexto/história
    const contextoHtml = it.contexto ? `<div class="panel-section"><h4>Contexto executivo</h4><div class="panel-text">${escapeHtml(it.contexto)}</div></div>` : '';
    const historiaHtml = it.historia ? `<div class="panel-section"><h4>Como user story</h4><div class="panel-text history">${escapeHtml(it.historia)}</div></div>` : '';

    // RICE
    const riceHtml = it.rice ? `<div class="panel-section"><h4>RICE · prioridade quantificada</h4>
      <div class="kpi-grid">
        <div class="kpi-cell"><div class="kpi-l">Reach</div><div class="kpi-v">${it.rice.reach||'—'}</div></div>
        <div class="kpi-cell"><div class="kpi-l">Impact</div><div class="kpi-v">${it.rice.impact||'—'}</div></div>
        <div class="kpi-cell"><div class="kpi-l">Conf.</div><div class="kpi-v">${it.rice.confidence||'—'}</div></div>
        <div class="kpi-cell score"><div class="kpi-l">Score</div><div class="kpi-v">${it.rice.score||'—'}</div></div>
      </div></div>` : '';

    // Critérios de aceite (lista simples · id + texto)
    const caHtml = it.criterios_aceite && it.criterios_aceite.length ? `<div class="panel-section">
      <h4>Critérios de aceite <span class="h4-count">${it.criterios_aceite.length}</span></h4>
      <div class="ca-list">
        ${it.criterios_aceite.map(c => `<div class="ca-card">
          <div class="ca-line"><span class="ca-tag">${escapeHtml(c.id||'CA')}</span><span>${escapeHtml(c.texto)}</span></div>
        </div>`).join('')}
      </div></div>` : '';

    // Riscos
    const riscosHtml = it.riscos && it.riscos.length ? `<div class="panel-section">
      <h4>Riscos <span class="h4-count">${it.riscos.length}</span></h4>
      <ul class="bullet-list risk">${it.riscos.map(r=>`<li>${escapeHtml(r)}</li>`).join('')}</ul>
    </div>` : '';

    // Premissas
    const premHtml = it.premissas && it.premissas.length ? `<div class="panel-section">
      <h4>Premissas <span class="h4-count">${it.premissas.length}</span></h4>
      <ul class="bullet-list prem">${it.premissas.map(p=>`<li>${escapeHtml(p)}</li>`).join('')}</ul>
    </div>` : '';

    // Observações do PO
    const obsHtml = it.observacoes_po ? `<div class="panel-section"><h4>Observações do PO</h4><div class="panel-text">${escapeHtml(it.observacoes_po)}</div></div>` : '';

    // Tags
    const tagsHtml = it.tags && it.tags.length ? `<div class="panel-section"><h4>Tags</h4><div class="tags-row">${it.tags.map(t=>`<span class="tag-chip">#${escapeHtml(t)}</span>`).join('')}</div></div>` : '';

    // Subtarefas (clicáveis)
    const subList = it.subtarefas.length ? `<div class="panel-section">
      <h4>Subtarefas <span class="h4-count">${it.subtarefas.length}</span></h4>
      <div class="subs-list">
        ${it.subtarefas.map(st => `<div class="sub-card ${st.isGate?'gate':''} ${selectedSub && selectedSub.subId===st.id?'sel':''}" data-sub="${st.id}">
          <span class="sc-id">${st.id}</span>
          <span class="sc-t">${escapeHtml(st.title)}</span>
          <span class="sc-meta">${st.esforco||'—'}<br>${escapeHtml(st.responsavel?st.responsavel.split(' ')[0]:'—')}</span>
        </div>`).join('')}
      </div></div>` : '';

    // Relações
    const depsHtml = it.dependencias.length ? `<div class="panel-section"><h4>Depende de <span class="h4-count">${it.dependencias.length}</span></h4><div class="rel-chips">${it.dependencias.map(d => `<span class="rel-chip dep" data-goto="${d}">${d}</span>`).join('')}</div></div>` : '';
    const blqHtml = it.bloqueia.length ? `<div class="panel-section"><h4>Bloqueia <span class="h4-count">${it.bloqueia.length}</span></h4><div class="rel-chips">${it.bloqueia.map(d => `<span class="rel-chip blq" data-goto="${d}">${d}</span>`).join('')}</div></div>` : '';
    const absorvHtml = it.absorvido_por ? `<div class="panel-section"><h4>Absorvido por</h4><div class="rel-chips"><span class="rel-chip" data-goto="${it.absorvido_por}">${it.absorvido_por}</span></div></div>` : '';
    const motivoHtml = it.motivo_cancelamento ? `<div class="panel-section"><h4>Motivo do cancelamento</h4><div class="panel-text muted">${escapeHtml(it.motivo_cancelamento)}</div></div>` : '';

    panel.innerHTML = `
      <div>
        <div class="ph">Item selecionado</div>
        <div class="detail-card" style="--c:${f.color}">
          <div class="d-id">${it.id} · ${escapeHtml(f.label.split('·')[0].trim())}</div>
          <div class="d-title">${escapeHtml(it.title)}</div>
          <div class="d-tags">
            <span class="badge ${it.status}">${STATUS_LABELS[it.status]}</span>
            <span class="badge ${it.prioridade}">${PRIO_LABELS[it.prioridade]||it.prioridade}</span>
            ${it.esforco?`<span class="badge baixa">${it.esforco}</span>`:''}
            ${it.refinada?'<span class="badge refinado">✓ Refinada</span>':''}
          </div>
          <dl class="d-grid">
            <dt>Sponsor</dt><dd>${escapeHtml(it.sponsor||'—')}</dd>
            <dt>Owner</dt><dd>${escapeHtml(it.owner||'—')}</dd>
            ${it.implementador?`<dt>Implementador</dt><dd>${escapeHtml(it.implementador)}</dd>`:''}
            <dt>Deadline</dt><dd class="${it.deadline?'mono':'muted'}">${it.deadline||'— a definir'}</dd>
            ${it.origem?`<dt>Origem</dt><dd>${escapeHtml(it.origem)}</dd>`:''}
            ${it.roadmap?`<dt>Roadmap</dt><dd class="mono">${escapeHtml(it.roadmap)}</dd>`:''}
          </dl>
          ${it.valor_negocio?`<div class="d-context"><strong style="color:var(--text);font-weight:600">Valor de negócio: </strong>${escapeHtml(it.valor_negocio)}</div>`:''}
        </div>
      </div>
      ${motivoHtml}
      ${absorvHtml}
      ${contextoHtml}
      ${historiaHtml}
      ${riceHtml}
      ${depsHtml}
      ${blqHtml}
      ${caHtml}
      ${riscosHtml}
      ${premHtml}
      ${obsHtml}
      ${subList}
      ${tagsHtml}
      <div class="panel-section"><h4>Ações</h4><div class="rel-chips"><a class="rel-chip" href="Backlog.html" target="_blank" style="text-decoration:none">Abrir no backlog ↗</a></div></div>
    `;
    panel.querySelectorAll('[data-goto]').forEach(c => c.onclick = () => navigateToItem(c.dataset.goto));
    panel.querySelectorAll('[data-sub]').forEach(c => c.onclick = () => selectSubtarefa(it.id, c.dataset.sub));
    return;
  }

  // === Frente selecionada ===
  if(selectedFrente){
    const f = FRENTES[selectedFrente];
    const allItems = ITEMS.filter(i => i.frente === selectedFrente);
    const its = activeItems(selectedFrente);
    const byStatus = {};
    its.forEach(i => byStatus[i.status] = (byStatus[i.status]||0)+1);
    const buckets = bucketsForFrente(selectedFrente);
    const histCount = allItems.length - its.length;
    const totSubs = its.reduce((a,i)=>a+i.subtarefas.length, 0);
    const totDeps = its.reduce((a,i)=>a+i.dependencias.length, 0);
    const refinadas = its.filter(i=>i.refinada).length;
    // Foco: item with highest priority, then highest RICE
    const foco = [...its].sort((a,b) => {
      const pa = PRIO_ORDER.indexOf(a.prioridade), pb = PRIO_ORDER.indexOf(b.prioridade);
      if(pa !== pb) return pa - pb;
      return (b.rice?.score||0) - (a.rice?.score||0);
    })[0];

    panel.innerHTML = `
      <div>
        <div class="ph">Frente selecionada</div>
        <div class="detail-card" style="--c:${f.color}">
          <div class="d-id">${escapeHtml(f.prefix)}## · ${its.length} ativos / ${allItems.length} total</div>
          <div class="d-title">${escapeHtml(f.label)}</div>
          <dl class="d-grid">
            <dt>Sponsor</dt><dd>${escapeHtml(f.sponsor)}</dd>
            <dt>Plataforma</dt><dd>${escapeHtml(f.plataforma||'—')}</dd>
          </dl>
          ${f.desc?`<div class="d-context">${escapeHtml(f.desc)}</div>`:''}
        </div>
      </div>

      <div class="panel-section">
        <h4>Visão da frente</h4>
        <div class="kpi-grid">
          <div class="kpi-cell"><div class="kpi-l">Ativos</div><div class="kpi-v">${its.length}</div></div>
          <div class="kpi-cell"><div class="kpi-l">Refinados</div><div class="kpi-v">${refinadas}</div></div>
          <div class="kpi-cell"><div class="kpi-l">Subtarefas</div><div class="kpi-v">${totSubs}</div></div>
          <div class="kpi-cell"><div class="kpi-l">Deps</div><div class="kpi-v">${totDeps}</div></div>
        </div>
      </div>

      <div class="panel-section">
        <h4>Distribuição por status</h4>
        <div class="rel-chips">
          ${Object.entries(byStatus).sort((a,b)=>b[1]-a[1]).map(([s,n]) => `<span class="badge ${s}" style="font-size:10px">${STATUS_LABELS[s]} · ${n}</span>`).join('')}
          ${histCount?`<span class="badge cancelado" style="font-size:10px;opacity:.7">+ ${histCount} concluídos/cancelados</span>`:''}
        </div>
      </div>

      ${foco ? `<div class="panel-section">
        <h4>Item-foco recomendado</h4>
        <div class="sub-card sel" data-goto="${foco.id}" style="border-color:${f.color};outline-color:${f.color}">
          <span class="sc-id" style="color:${f.color}">${foco.id}</span>
          <span class="sc-t">${escapeHtml(foco.title)}</span>
          <span class="sc-meta">${foco.rice?'RICE '+foco.rice.score:foco.prioridade}</span>
        </div>
      </div>` : ''}

      ${buckets.map(prio => {
        const bItems = its.filter(i => i.prioridade === prio).sort(sortByImpact);
        return `
          <div class="panel-section">
            <h4 style="color:${PRIO_COLOR[prio]}">${PRIO_LBL[prio]} <span class="h4-count">${bItems.length}</span></h4>
            <div class="subs-list">
              ${bItems.map(i => `<div class="sub-card" data-goto="${i.id}">
                <span class="sc-id">${i.id}</span>
                <span class="sc-t">${escapeHtml(i.title)}</span>
                <span class="sc-meta">${i.rice?.score?'RICE '+i.rice.score:(i.esforco||'—')}<br>${STATUS_LABELS[i.status].split(' ')[0]}</span>
              </div>`).join('')}
            </div>
          </div>
        `;
      }).join('')}
    `;
    panel.querySelectorAll('[data-goto]').forEach(c => c.onclick = () => navigateToItem(c.dataset.goto));
    return;
  }

  // === Empty state ===
  panel.innerHTML = `
    <div>
      <div class="ph">Mapa interativo</div>
      <div class="pn-empty">
        <strong>Squad IAF · 30 itens · 7 frentes</strong>
        Canvas tipo Miro · explore o backlog clicando, arrastando, dando zoom.
        <ul>
          <li><kbd>clique</kbd> em uma <strong>frente</strong> para abrir buckets de prioridade</li>
          <li><kbd>clique</kbd> num <strong>bucket</strong> para ver os itens ordenados por impacto</li>
          <li><kbd>clique</kbd> num <strong>item</strong> para ver contexto, RICE, critérios, riscos e subtarefas</li>
          <li><kbd>clique</kbd> numa <strong>subtarefa</strong> para detalhe + responsável + prazo</li>
          <li>Linhas <span style="color:#F59E0B;font-weight:600">laranja tracejadas</span> = depende de</li>
          <li>Linhas <span style="color:#EF4444;font-weight:600">vermelhas tracejadas</span> = bloqueia</li>
          <li><kbd>arraste</kbd> nós · <kbd>scroll</kbd> para zoom · <kbd>arraste o fundo</kbd> para pan</li>
        </ul>
      </div>
    </div>
    <div>
      <div class="ph">Ir para uma frente</div>
      <div class="bucket-pill-row">
        ${DATA.frentes.map(f => `<span class="bucket-pill" data-frente="${f.key}" style="border-color:${f.color};color:${f.color};background:rgba(0,0,0,0)">${escapeHtml(f.label.split('·')[0].trim())}<span class="bp-n" style="color:${f.color};border:1px solid ${f.color}30">${activeItems(f.key).length}</span></span>`).join('')}
      </div>
    </div>
  `;
  panel.querySelectorAll('[data-frente]').forEach(c => {
    c.onclick = () => {
      const k = c.dataset.frente;
      if(!expandedFrentes.has(k)) expandedFrentes.add(k);
      selectedFrente = k; selectedItem = null; selectedSub = null;
      ensureBucketPositions(k);
      panTo(positions['frente:'+k]);
      render(); persist();
    };
  });
}

function applySearchVisual(){
  const q = searchQ.toLowerCase().trim();
  if(!q){
    document.querySelectorAll('.node').forEach(n => {n.classList.remove('dim'); n.classList.remove('match');});
    matchedIds.clear();
    return;
  }
  matchedIds.clear();
  ITEMS.forEach(i => {
    if(i.id.toLowerCase().includes(q) || i.title.toLowerCase().includes(q)) matchedIds.add(i.id);
  });
  document.querySelectorAll('.node').forEach(n => {
    const key = n.dataset.key||'';
    if(!key){n.classList.add('dim');return;}
    if(key.startsWith('item:')){
      const id = key.slice(5);
      if(matchedIds.has(id)){n.classList.add('match');n.classList.remove('dim');}
      else {n.classList.add('dim');n.classList.remove('match');}
    } else if(key.startsWith('bucket:')){
      const [, fk, prio] = key.split(':');
      const hasMatch = ITEMS.some(i => i.frente===fk && i.prioridade===prio && matchedIds.has(i.id));
      if(hasMatch){n.classList.remove('dim');n.classList.remove('match');}
      else {n.classList.add('dim');n.classList.remove('match');}
    } else if(key.startsWith('frente:')){
      const fk = key.slice(7);
      const has = ITEMS.some(i => i.frente===fk && matchedIds.has(i.id));
      if(has){n.classList.remove('dim');n.classList.remove('match');}
      else{n.classList.add('dim');n.classList.remove('match');}
    } else {
      n.classList.add('dim');
    }
  });
}

// ===== Actions =====
function toggleFrente(key){
  if(expandedFrentes.has(key)){
    expandedFrentes.delete(key);
    // collapse buckets and items in this frente
    [...expandedBuckets].forEach(b => { if(b.startsWith(key+'|')) expandedBuckets.delete(b); });
    ITEMS.filter(i => i.frente === key).forEach(i => expandedItems.delete(i.id));
  } else {
    expandedFrentes.add(key);
    ensureBucketPositions(key);
  }
  selectedFrente = key;
  selectedItem = null;
  render(); persist();
}
function toggleBucket(fk, prio){
  const key = fk+'|'+prio;
  if(expandedBuckets.has(key)){
    expandedBuckets.delete(key);
    activeItems(fk).filter(i => i.prioridade === prio).forEach(i => expandedItems.delete(i.id));
  } else {
    expandedBuckets.add(key);
    ensureItemPositions(fk, prio);
  }
  render(); persist();
}
function selectItem(id){
  selectedItem = id;
  selectedFrente = null;
  selectedSub = null;
  if(expandedItems.has(id)) expandedItems.delete(id);
  else { expandedItems.add(id); ensureSubPositions(id); }
  render(); persist();
}
function selectSubtarefa(itemId, subId){
  selectedSub = {itemId, subId};
  selectedItem = itemId;
  selectedFrente = null;
  render(); persist();
}
function navigateToItem(id){
  const it = ITEMS_BY_ID[id];
  if(!it) return;
  selectedItem = id;
  selectedFrente = null;
  // Cancelados não aparecem no mapa — só atualiza painel
  if(it.status === 'cancelado'){
    render(); persist(); return;
  }
  if(it.status === 'entregue' && !showHistorico){
    showHistorico = true; updateHistoricoBtn();
  }
  if(!expandedFrentes.has(it.frente)) {
    expandedFrentes.add(it.frente);
    ensureBucketPositions(it.frente);
  }
  const bkey = it.frente+'|'+it.prioridade;
  if(!expandedBuckets.has(bkey)){
    expandedBuckets.add(bkey);
    ensureItemPositions(it.frente, it.prioridade);
  }
  panTo(positions['item:'+id]);
  render(); persist();
}
function panTo(worldPos){
  const rect = viewport.getBoundingClientRect();
  // we want world point at viewport center
  pan.x = -worldPos.x * zoom;
  pan.y = -worldPos.y * zoom;
}
function resetAll(){
  if(!confirm('Resetar posições e estado do mapa?')) return;
  positions = {};
  expandedFrentes.clear();
  expandedBuckets.clear();
  expandedItems.clear();
  selectedItem = null; selectedFrente = null;
  pan = {x:0, y:0}; zoom = 1;
  searchQ = ''; searchInput.value = '';
  showHistorico = false; updateHistoricoBtn();
  ensureFrentePositions();
  render(); persist();
}
function collapseAll(){
  expandedFrentes.clear();
  expandedBuckets.clear();
  expandedItems.clear();
  render(); persist();
}
function fitView(){
  pan = {x:0, y:0}; zoom = 1;
  applyTransform(); persist();
}

// ===== Interactions on nodes =====
function attachInteractions(el, onClick){
  let startX, startY, origPos, moved, downTime;
  el.addEventListener('mousedown', e => {
    if(e.button !== 0) return;
    e.stopPropagation();
    startX = e.clientX; startY = e.clientY;
    moved = false;
    downTime = Date.now();
    const key = el.dataset.key;
    origPos = positions[key] ? {...positions[key]} : null;
    const onMove = ev => {
      const dx = ev.clientX - startX, dy = ev.clientY - startY;
      if(!moved && Math.abs(dx)+Math.abs(dy) > 4){moved = true; el.classList.add('dragging');}
      if(moved && origPos){
        positions[key] = {x: origPos.x + dx/zoom, y: origPos.y + dy/zoom};
        el.style.left = positions[key].x + 'px';
        el.style.top = positions[key].y + 'px';
        // re-render links on the fly
        const visibleItemIds = new Set();
        expandedFrentes.forEach(fk => {
          bucketsForFrente(fk).forEach(prio => {
            if(expandedBuckets.has(fk+'|'+prio)){
              activeItems(fk).filter(i => i.prioridade === prio).forEach(i => visibleItemIds.add(i.id));
            }
          });
        });
        renderLinks(visibleItemIds);
      }
    };
    const onUp = () => {
      window.removeEventListener('mousemove', onMove);
      window.removeEventListener('mouseup', onUp);
      el.classList.remove('dragging');
      if(!moved){ onClick(); }
      else persist();
    };
    window.addEventListener('mousemove', onMove);
    window.addEventListener('mouseup', onUp);
  });
}

// ===== Pan / zoom on viewport =====
let panning = false, panStart = null;
viewport.addEventListener('mousedown', e => {
  if(e.target.closest('.node')) return;
  if(e.button !== 0) return;
  panning = true;
  panStart = {x:e.clientX, y:e.clientY, px:pan.x, py:pan.y};
  viewport.classList.add('panning');
});
window.addEventListener('mousemove', e => {
  if(!panning) return;
  pan.x = panStart.px + (e.clientX - panStart.x);
  pan.y = panStart.py + (e.clientY - panStart.y);
  applyTransform();
});
window.addEventListener('mouseup', () => {
  if(panning){panning = false; viewport.classList.remove('panning'); persist();}
});
viewport.addEventListener('wheel', e => {
  e.preventDefault();
  const rect = viewport.getBoundingClientRect();
  const cx = e.clientX - rect.left - rect.width/2;
  const cy = e.clientY - rect.top - rect.height/2;
  const factor = e.deltaY < 0 ? 1.12 : 1/1.12;
  const newZoom = Math.max(0.18, Math.min(2.8, zoom * factor));
  const worldX = (cx - pan.x)/zoom;
  const worldY = (cy - pan.y)/zoom;
  pan.x = cx - worldX * newZoom;
  pan.y = cy - worldY * newZoom;
  zoom = newZoom;
  applyTransform(); persist();
}, {passive:false});

// ===== Toolbar =====
document.getElementById('btn-zoom-in').onclick = () => { zoom = Math.min(2.8, zoom*1.15); applyTransform(); persist(); };
document.getElementById('btn-zoom-out').onclick = () => { zoom = Math.max(0.18, zoom/1.15); applyTransform(); persist(); };
document.getElementById('btn-fit').onclick = fitView;
document.getElementById('btn-collapse').onclick = collapseAll;
document.getElementById('btn-reset').onclick = resetAll;
function updateHistoricoBtn(){
  const b = document.getElementById('btn-hist');
  if(!b) return;
  b.textContent = showHistorico ? '● Entregues visíveis' : '○ Entregues ocultos';
  b.style.color = showHistorico ? 'var(--success)' : '';
}
document.getElementById('btn-hist').onclick = () => {
  showHistorico = !showHistorico;
  updateHistoricoBtn();
  render(); persist();
};
updateHistoricoBtn();

// Search
let searchTimer;
searchInput.addEventListener('input', e => {
  clearTimeout(searchTimer);
  searchTimer = setTimeout(() => {
    searchQ = e.target.value;
    // auto-expand frentes that contain matches
    if(searchQ.trim()){
      const q = searchQ.toLowerCase();
      ITEMS.forEach(i => {
        if(i.status === 'cancelado') return;
        if(i.id.toLowerCase().includes(q) || i.title.toLowerCase().includes(q)){
          if(i.status === 'entregue' && !showHistorico){
            showHistorico = true; updateHistoricoBtn();
          }
          expandedFrentes.add(i.frente);
          ensureBucketPositions(i.frente);
          const bkey = i.frente+'|'+i.prioridade;
          expandedBuckets.add(bkey);
          ensureItemPositions(i.frente, i.prioridade);
        }
      });
      render();
    } else {
      applySearchVisual();
    }
  }, 150);
});

// Keyboard
document.addEventListener('keydown', e => {
  if(document.activeElement === searchInput) return;
  if(e.key === 'Escape'){selectedItem = null; selectedFrente = null; selectedSub = null; render(); persist();}
  if(e.key === '0'){fitView();}
  if(e.key === '+' || e.key === '='){document.getElementById('btn-zoom-in').click();}
  if(e.key === '-'){document.getElementById('btn-zoom-out').click();}
});

// Init
ensureFrentePositions();
render();
</script>
</body>
</html>